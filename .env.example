# auto = en release mode prefiere Supabase Auth si las credenciales están configuradas
# local = fuerza auth local del laboratorio
# supabase = fuerza Supabase Auth
VITE_LAB_AUTH_STRATEGY=auto
VITE_LAB_GOOGLE_SIGNIN=false
VITE_LAB_MFA=true
# isolated = usa namespace produ-lab:* con clone/seeds de laboratorio
# release = usa namespace produ:* y desactiva clone/seeds automáticos
VITE_LAB_DATA_MODE=isolated
# activa Tesorería explícitamente en release/productivo cuando el rollout financiero esté validado
VITE_ENABLE_TREASURY=false
# para revisar el release candidate localmente:
# npm run dev:release
# Required for storage and optional Supabase Auth flows
VITE_SUPABASE_URL=https://zpgxbmlzoxxgymsschrd.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
